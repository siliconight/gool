{
  "_comment": "Co-op shooter template audio config. Multi-tier sidechain ducking: LocalSfx > RemoteSfx > Music. The local player's gunshots duck both the music AND the remote teammates' gunshots. Loaded by gool's runtime_singleton at startup; the GoolAudioRuntime parses this server-side and constructs the bus graph before Initialize().",

  "sample_rate": 48000,
  "buffer_size": 512,

  "buses": [
    { "name": "Master", "gain_db": 0.0 },

    { "name": "Music", "parent": "Master", "gain_db": -3.0,
      "effects": [
        { "kind": "compressor",
          "threshold_db": -28.0, "ratio": 8.0,
          "attack_ms":     5.0,  "release_ms": 250.0,
          "knee_width_db": 4.0,
          "max_reduction_db": 12.0,
          "sidechain_bus": "LocalSfx" }
      ] },

    { "name": "SfxAll", "parent": "Master" },

    { "name": "LocalSfx", "parent": "SfxAll" },

    { "name": "RemoteSfx", "parent": "SfxAll",
      "effects": [
        { "kind": "compressor",
          "threshold_db": -28.0, "ratio": 6.0,
          "attack_ms":     5.0,  "release_ms": 200.0,
          "knee_width_db": 4.0,
          "max_reduction_db": 9.0,
          "sidechain_bus": "LocalSfx" }
      ] },

    { "name": "Voice",   "parent": "Master", "gain_db": 0.0 },
    { "name": "Ambient", "parent": "Master", "gain_db": -6.0 }
  ],

  "category_routing": {
    "music":    "Music",
    "sfx":      "LocalSfx",
    "voice":    "Voice",
    "ambience": "Ambient",
    "ui":       "Master",
    "dialogue": "Voice"
  }
}
