; gool audition example — hub-and-spokes reverb auditioning scene
;
; Demonstrates v0.47.0+ feature set in a runnable single-player walkthrough:
;   - Hub with Outdoor Open reverb + 4 enclosed rooms
;   - Real wall occlusion (StaticBody3D walls)
;   - Per-room material targets (Wood / Concrete / Glass / Metal / Foliage / Drywall)
;   - DialogueDirector bark + sidechain ducking
;   - GoolMixSnapshot capture/apply
;   - F3 debug overlay
;
; Open this project in Godot 4.x with the gool addon enabled.

config_version=5

[application]

config/name="gool audition"
config/description="Reverb + occlusion + material auditioning scene"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.2")
config/icon="res://icon.svg"

[autoload]

Gool="*res://addons/gool/runtime_singleton.gd"
DialogueDirector="*res://addons/gool/dialogue_director.gd"
GoolMultiplayerBridge="*res://addons/gool/multiplayer_bridge.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/gool/plugin.cfg")

[input]

move_forward={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":87,"key_label":0,"unicode":119,"echo":false,"script":null)
]
}
