[gd_resource type="Resource" script_class="GoolAcousticProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/gool/resources/gool_acoustic_profile.gd" id="1_profile"]

[resource]
script = ExtResource("1_profile")
profile_name = "Dry forest"
description = "Outdoor forest — minimal tail, heavy HF damping from foliage, low diffusion. Use for forests, dense vegetation, outdoor wooded."
profile_schema_version = 1
reverb_decay = 0.2
reverb_lf_damping = 0.2
reverb_hf_damping = 0.65
reverb_diffusion = 0.3
reverb_predelay_ms = 15.0
reverb_wet_gain_db = -18.0
