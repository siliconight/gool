[ext_resource type="Script" path="res://addons/gool/resources/gool_master_fx_preset.gd" id="1_preset"]

[resource]
script = ExtResource("1_preset")
preset_name = "Standard FPS"
description = "The v0.63.0 default. Moderate compression for cohesion, -16 LUFS target matching the design doc's 'Default' profile, brickwall at -1 dBTP. Recommended starting point for most multiplayer shooters and action games."
preset_schema_version = 1
glue_enabled = true
rider_enabled = true
limiter_enabled = true
glue_threshold_db = -12.0
glue_ratio = 2.0
glue_attack_ms = 10.0
glue_release_ms = 250.0
glue_knee_db = 6.0
glue_makeup_db = 0.0
rider_target_lufs = -16.0
rider_time_constant_ms = 3000.0
rider_max_gain_db = 6.0
rider_min_gain_db = -6.0
rider_freeze_below_lufs = -6.0
limiter_ceiling_dbtp = -1.0
limiter_release_ms = 50.0
limiter_lookahead_ms = 5.0
