# addons/gool/.editorconfig
#
# Godot 4.x and most editors respect EditorConfig files. This file
# scopes its rules to files inside the gool addon — it does NOT
# affect your project's own scripts (provided your project has its
# own .editorconfig with root = true).
#
# As of v0.23.14: gool's source uses TABS for indentation, matching
# Godot's official GDScript style guide. Earlier releases (v0.23.5
# through v0.23.13) tried to use spaces with EditorConfig enforcing
# them, but the Godot editor's tab-default conversion behavior
# caused mixed-indentation parse errors when users opened addon
# files in the script editor and made local edits. Aligning with
# Godot's tabs convention eliminates the conflict entirely.
#
# Reference: https://docs.godotengine.org/en/stable/tutorials/scripting/gdscript/gdscript_styleguide.html#indentation

root = false

[*.gd]
indent_style = tab
indent_size = 4
tab_width = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.tres]
indent_style = tab
indent_size = 4
tab_width = 4
insert_final_newline = true

[*.tscn]
indent_style = tab
indent_size = 4
tab_width = 4
insert_final_newline = true
