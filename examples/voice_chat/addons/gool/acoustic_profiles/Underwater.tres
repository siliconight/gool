[gd_resource type="Resource" script_class="GoolAcousticProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/gool/resources/gool_acoustic_profile.gd" id="1_profile"]

[resource]
script = ExtResource("1_profile")
profile_name = "Underwater"
description = "Submerged space — moderate tail, heavy HF damping (water absorbs HF), kept lows. Pairs with the Underwater EQ preset on impacts."
profile_schema_version = 1
reverb_decay = 0.5
reverb_lf_damping = 0.05
reverb_hf_damping = 0.85
reverb_diffusion = 0.65
reverb_predelay_ms = 25.0
reverb_wet_gain_db = -9.0
