[ext_resource type="Script" path="res://addons/gool/resources/gool_master_fx_preset.gd" id="1_preset"]

[resource]
script = ExtResource("1_preset")
preset_name = "Cinema / quiet"
description = "Story-driven content with cinematic dynamic range. Very light compression preserves emotional dynamics, -22 LUFS target matching the design doc's 'Night mode' profile, ceiling held in reserve. The mix breathes; loud moments stay loud relative to quiet ones."
preset_schema_version = 1
glue_enabled = true
rider_enabled = true
limiter_enabled = true
glue_threshold_db = -16.0
glue_ratio = 1.3
glue_attack_ms = 25.0
glue_release_ms = 600.0
glue_knee_db = 10.0
glue_makeup_db = 0.0
rider_target_lufs = -22.0
rider_time_constant_ms = 5000.0
rider_max_gain_db = 3.0
rider_min_gain_db = -3.0
rider_freeze_below_lufs = -8.0
limiter_ceiling_dbtp = -1.5
limiter_release_ms = 120.0
limiter_lookahead_ms = 5.0
