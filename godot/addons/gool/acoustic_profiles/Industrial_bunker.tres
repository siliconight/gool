[gd_resource type="Resource" script_class="GoolAcousticProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/gool/resources/gool_acoustic_profile.gd" id="1_profile"]

[resource]
script = ExtResource("1_profile")
profile_name = "Industrial bunker"
description = "Concrete + steel hard interior — medium tail, slight HF retention, bright slap. Use for bunkers, machine rooms, industrial interiors."
profile_schema_version = 1
reverb_decay = 0.55
reverb_lf_damping = 0.15
reverb_hf_damping = 0.3
reverb_diffusion = 0.55
reverb_predelay_ms = 30.0
reverb_wet_gain_db = -11.0
