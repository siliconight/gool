[gd_resource type="Resource" script_class="GoolAcousticProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/gool/resources/gool_acoustic_profile.gd" id="1_profile"]

[resource]
script = ExtResource("1_profile")
profile_name = "Tight corridor"
description = "Narrow hard-walled hallway — short tail, fast flutter, slight HF brightness. Use for corridors, narrow tunnels, stairwells."
profile_schema_version = 1
reverb_decay = 0.35
reverb_lf_damping = 0.15
reverb_hf_damping = 0.35
reverb_diffusion = 0.45
reverb_predelay_ms = 8.0
reverb_wet_gain_db = -14.0
