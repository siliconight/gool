[gd_resource type="Resource" script_class="GoolMasterFxPreset" load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/gool/resources/gool_master_fx_preset.gd" id="1_preset"]

[resource]
script = ExtResource("1_preset")
preset_name = "None / bypass"
description = "Chain installed but all stages disabled. Use to A/B-compare your raw mix against any of the active presets. No glue, no rider, no limiter — your project's bus topology and per-effect settings carry the whole mix."
